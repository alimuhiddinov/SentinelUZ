@startuml A3_activity_agent_pipeline
skinparam backgroundColor #FFFFFF
skinparam activity {
  BackgroundColor #EFF6FF
  BorderColor #1E3A5F
  FontColor #1E293B
  DiamondBackgroundColor #FEF3C7
  DiamondBorderColor #D97706
}
title SentinelUZ Agent — Detection Pipeline Activity

start

:Agent starts as Windows service (SYSTEM account);
:Load config from registry / config file;
:Register with server (POST /api/agent/register/);

repeat
  fork
    :Collect running processes\n(snapshot every 30s);
    :Compute SHA-256 for each executable;
    :Check hash against local TI cache;
    if (Hash matches known malware?) then (yes)
      :Score += CRITICAL weight;
      :Flag: HASH_MATCH;
    endif
    :Check process name against\nknown attack tool list;
    if (Known tool detected?) then (yes)
      :Score += CRITICAL weight;
      :Flag: KNOWN_ATTACK_TOOL;
    endif
    :Check parent-child process chain;
    if (Suspicious chain?) then (yes)
      :Score += HIGH weight;
      :Flag: SUSPICIOUS_CHAIN;
    endif
  fork again
    :Collect network connections\n(active sockets every 30s);
    :Check destination IPs against TI;
    if (Malicious IP?) then (yes)
      :Score += HIGH weight;
      :Flag: MALICIOUS_IP;
    endif
    :Check for beacon pattern\n(regular interval connections);
    if (Beacon detected?) then (yes)
      :Score += HIGH weight;
      :Flag: C2_BEACON;
    endif
  fork again
    :Collect file system events\n(CreateFile, WriteFile, DeleteFile);
    :Check file extensions\n(mass encryption pattern);
    if (Ransomware pattern?) then (yes)
      :Score += CRITICAL weight;
      :Flag: RANSOMWARE_INDICATOR;
    endif
  end fork

  :Calculate delta score\n(weighted sum of all flags);

  if (Delta score >= threshold?) then (yes)
    :POST /api/agent/alert/ to server;
    :Include: process list, flags, score, timestamp;
    :Server creates Alert record;
    :Analyst notified on dashboard;
  else (no)
    :POST /api/agent/heartbeat/ (telemetry only);
    :Server stores events, no alert;
  endif

  :Wait 30 seconds;

repeat while (Service running?) is (yes)

:Service stopped — deregister;
stop
@enduml
