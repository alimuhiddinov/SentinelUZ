@startuml A5_sequence_agent_registration
skinparam backgroundColor #FFFFFF
skinparam sequence {
  ArrowColor #1E3A5F
  ParticipantBackgroundColor #F8FAFC
  ParticipantBorderColor #CBD5E1
  NoteBackgroundColor #FEF9EE
  NoteBorderColor #D97706
}
title Agent Registration and Heartbeat Sequence

actor "IT Admin" as ADMIN
participant "SentinelUZ Agent\n(Windows Service)" as AGENT
participant "Django REST API\n(edr_server)" as API
database "PostgreSQL" as DB
participant "Dashboard\n(Analyst)" as UI

== Installation ==
ADMIN -> AGENT : Install agent\nSentinelUZAgent.exe --install
AGENT -> AGENT : Install as Windows service\nStart as SYSTEM
AGENT -> AGENT : Load server URL from config

== Registration ==
AGENT -> API : POST /api/agent/register/\n{hostname, os_version, ip, agent_version}
API -> DB : Endpoint.objects.get_or_create(\nhostname=hostname)
DB --> API : endpoint record
API --> AGENT : 200 {endpoint_id, agent_token, ti_version}
note right of AGENT
  Agent stores endpoint_id
  and auth token locally
  Uses token on all future requests
end note

== Normal Heartbeat (every 30 seconds) ==
loop Every 30 seconds
  AGENT -> AGENT : Collect processes,\nnetwork, file events
  AGENT -> AGENT : Run detection checks\ncompute delta score
  alt Score below threshold
    AGENT -> API : POST /api/agent/heartbeat/\n{endpoint_id, events[], score}
    API -> DB : Event.objects.bulk_create()
    API --> AGENT : 200 {ti_update: false}
  else Score above threshold
    AGENT -> API : POST /api/agent/alert/\n{endpoint_id, events[], score, flags[]}
    API -> DB : Alert.objects.create(\nseverity=CRITICAL, flags=flags)
    API -> DB : Event.objects.bulk_create()
    API --> AGENT : 200 {alert_id, action: MONITOR}
    UI -> DB : GET /api/alerts/ (polling)
    DB --> UI : new alert appears
    UI -> UI : Badge increments\nNotification shown
  end
end

== TI Update ==
API -> AGENT : 200 {ti_update: true, ti_version: N}
AGENT -> API : GET /api/ti/hashes/?since=version_N
API --> AGENT : {hashes: [...new hashes...]}
AGENT -> AGENT : Update local TI cache
@enduml
