@startuml A2_use_case_threat_actor
skinparam backgroundColor #FFFFFF
skinparam usecase {
  BackgroundColor #FFF7ED
  BorderColor #EA580C
  FontColor #1E293B
}
left to right direction
title SentinelUZ EDR — Threat Actor Use Cases

actor "Malware\nProcess" as MAL #FEE2E2
actor "Lateral Movement\nAttacker" as LAT #FEE2E2
actor "Ransomware\nOperator" as RAN #FEE2E2
actor "Insider\nThreat" as INS #FEE2E2

package "Attack Techniques SentinelUZ Detects" {
  usecase "Execute known malware\n(hash match)" as T1
  usecase "Use Mimikatz / BloodHound\n(known tool detection)" as T2
  usecase "Spawn suspicious process\n(Word → cmd → PowerShell)" as T3
  usecase "Abuse LOLBin\n(certutil, mshta, regsvr32)" as T4
  usecase "Establish C2 beacon\n(network anomaly)" as T5
  usecase "Encrypt files\n(ransomware pattern)" as T6
  usecase "Move laterally\n(PsExec, WMI)" as T7
  usecase "Exfiltrate data\n(large outbound transfer)" as T8
  usecase "Escalate privileges\n(token manipulation)" as T9
  usecase "Disable security tools\n(process kill pattern)" as T10
}

package "SentinelUZ Detection Response" {
  usecase "Raise CRITICAL alert\nDelta score overflow" as D1
  usecase "Flag known tool\nKnown attack tool list" as D2
  usecase "Flag process chain\nParent-child anomaly" as D3
  usecase "Flag LOLBin abuse\nWhitelist deviation" as D4
  usecase "Flag C2 pattern\nBeacon interval detection" as D5
}

MAL --> T1
MAL --> T6
LAT --> T2
LAT --> T3
LAT --> T7
LAT --> T9
RAN --> T6
RAN --> T8
INS --> T8
INS --> T10

T1 ..> D1 : triggers
T2 ..> D2 : triggers
T3 ..> D3 : triggers
T4 ..> D4 : triggers
T5 ..> D5 : triggers
T6 ..> D1 : triggers
T7 ..> D3 : triggers
@enduml
