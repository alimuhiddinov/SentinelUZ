@startuml A4_activity_alert_triage
skinparam backgroundColor #FFFFFF
skinparam activity {
  BackgroundColor #F8FAFC
  BorderColor #1E3A5F
  DiamondBackgroundColor #DBEAFE
  DiamondBorderColor #2563EB
}
title Alert Triage Workflow — Analyst Procedure

start

:Alert appears on dashboard\n(CRITICAL or HIGH severity);
:Analyst clicks "Investigate";

:View alert detail page;
note right
  Shows: endpoint name, timestamp,
  detection type, delta score,
  process tree, flags triggered
end note

:Review process tree\non Endpoint Events tab;

if (Process looks legitimate?) then (yes)
  :Check exclusion rules;
  if (Should be excluded?) then (yes)
    :Add exclusion rule\n(process name + path);
    :Mark alert: FALSE POSITIVE;
    :Alert closed;
    stop
  else (no)
    :Mark alert: ACKNOWLEDGED;
    :Add analyst note;
    stop
  endif
else (no)
  :Review network connections\nfrom alert timeframe;
  if (C2 traffic detected?) then (yes)
    :Create Incident;
    :Link alert to incident;
    :Escalate: CRITICAL;
    :Notify IT Security Manager;
  else (no)
    :Assess blast radius;
  endif

  if (Isolated incident?) then (yes)
    :Mark alert: CONFIRMED THREAT;
    :Document in incident notes;
    :Remediate endpoint manually;
  else (no)
    :Create Incident;
    :Link related alerts;
    :Generate incident report;
    :Begin containment procedure;
  endif
endif

:Close alert with resolution note;
stop
@enduml
